using Glitching.AspNetCore;
using System.Threading.Tasks;

string BuildHealth() {
    return "{\"status\":\"ok\"}";
}

async Task<string> HealthAsync() {
    Task<string> work = Task.Run(BuildHealth);
    return await work;
}

fn main() {
    WebApplication app = new WebApplication();
    app.MapGet("/health", HealthAsync);
    app.RunOnce(5123);
}
