public class string {
    static bool IsNullOrEmpty(string value) {
        return value == null || value.Length == 0;
    }
    static bool IsNullOrWhiteSpace(string value) {
        return value == null || value.Length == 0;
    }
    string ToLower() { return System_String_ToLower_Native(this); }
    string ToLowerInvariant() { return System_String_ToLowerInvariant_Native(this); }
    string Substring(int start) { return System_String_Substring_Native(this, start); }
    string TrimEnd() { return System_String_TrimEnd_Native(this, null); }
    string TrimEnd(string chars) { return System_String_TrimEnd_Native(this, chars); }
    string TrimStart() { return System_String_TrimStart_Native(this, null); }
    string TrimStart(string chars) { return System_String_TrimStart_Native(this, chars); }
    string[] Split(string separator) { return System_String_Split_Native(this, separator); }
    string Replace(string old, string newStr) { return System_String_Replace_Native(this, old, newStr); }
    string Trim() { return System_String_Trim_Native(this); }
    bool Contains(string value) { return System_String_Contains_Native(this, value); }
    bool EndsWith(string value, StringComparison comparison) {
        if (value == null) {
            return false;
        }
        if (value.Length > this.Length) {
            return false;
        }
        int offset = this.Length - value.Length;
        int i = 0;
        while (i < value.Length) {
            if (this[offset + i] != value[i]) {
                return false;
            }
            i = i + 1;
        }
        return true;
    }
    bool StartsWith(string value, StringComparison comparison) {
        if (value == null) {
            return false;
        }
        if (value.Length > this.Length) {
            return false;
        }
        int i = 0;
        while (i < value.Length) {
            if (this[i] != value[i]) {
                return false;
            }
            i = i + 1;
        }
        return true;
    }
    bool Equals(string value, StringComparison comparison) {
        if (value == null) {
            return false;
        }
        if (this.Length != value.Length) {
            return false;
        }
        int i = 0;
        while (i < this.Length) {
            if (this[i] != value[i]) {
                return false;
            }
            i = i + 1;
        }
        return true;
    }
}

