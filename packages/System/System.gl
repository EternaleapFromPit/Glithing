public class Type {
    public static view<Type>[] EmptyTypes;
    public string Name;
    public string Namespace;
    public bool IsGenericType;
    public bool IsClass;
    public bool IsInterface;
    public bool IsValueType;
    public bool IsEnum;
    public bool IsArray;
    public string FullName;
    public string GenericTypeDefinitionName;
    public view<Type>[] GenericArguments;
    public view<Type> BaseType;
    public view<Type> ElementType;
    public PropertyInfo[] Properties;
    public MethodInfo[] Methods;
    public FieldInfo[] Fields;
    public ConstructorInfo[] Constructors;
    public view<Type>[] Interfaces;
    
    Type GetGenericTypeDefinition() {
        Type definition = new Type();
        definition.Name = this.Name;
        definition.Namespace = this.Namespace;
        definition.FullName = this.GenericTypeDefinitionName;
        definition.GenericTypeDefinitionName = this.GenericTypeDefinitionName;
        definition.IsGenericType = this.IsGenericType;
        definition.IsClass = this.IsClass;
        definition.IsInterface = this.IsInterface;
        definition.IsValueType = this.IsValueType;
        definition.IsEnum = this.IsEnum;
        definition.IsArray = this.IsArray;
        definition.BaseType = this.BaseType;
        definition.ElementType = this.ElementType;
        definition.GenericArguments = default(view<Type>[]);
        definition.Properties = default(PropertyInfo[]);
        definition.Methods = default(MethodInfo[]);
        definition.Fields = default(FieldInfo[]);
        definition.Constructors = default(ConstructorInfo[]);
        definition.Interfaces = default(view<Type>[]);
        return definition;
    }

    view<Type>[] GetGenericArguments() {
        return this.GenericArguments;
    }

    MethodInfo GetMethod(string name, Type[] types) {
        if (this.Methods == null) {
            return null;
        }
        int i = 0;
        while (i < this.Methods.Length) {
            var method = this.Methods[i];
            if (method != null && method.Name == name) {
                if (types == null || method.ParameterTypes == null || method.ParameterTypes.Length == types.Length) {
                    return method;
                }
            }
            i = i + 1;
        }
        return null;
    }

    MethodInfo[] GetMethods() {
        return this.Methods;
    }

    PropertyInfo GetProperty(string name, object flags) {
        if (this.Properties == null) {
            return null;
        }
        int i = 0;
        while (i < this.Properties.Length) {
            var property = this.Properties[i];
            if (property != null && property.Name == name) {
                return property;
            }
            i = i + 1;
        }
        return null;
    }

    PropertyInfo[] GetProperties() {
        return this.Properties;
    }

    FieldInfo GetField(string name, object flags) {
        if (this.Fields == null) {
            return null;
        }
        int i = 0;
        while (i < this.Fields.Length) {
            var field = this.Fields[i];
            if (field != null && field.Name == name) {
                return field;
            }
            i = i + 1;
        }
        return null;
    }

    FieldInfo[] GetFields() {
        return this.Fields;
    }

    ConstructorInfo[] GetConstructors() {
        return this.Constructors;
    }

    view<Type>[] GetInterfaces() {
        return this.Interfaces;
    }

    view<Type> GetElementType() {
        return this.ElementType;
    }

    bool IsAssignableFrom(Type other) {
        if (other == null) {
            return false;
        }
        if (this.FullName == other.FullName) {
            return true;
        }
        if (this.BaseType != null && this.BaseType.FullName == other.FullName) {
            return true;
        }
        return false;
    }

    bool IsInstanceOfType(object value) {
        return value != null;
    }
}

