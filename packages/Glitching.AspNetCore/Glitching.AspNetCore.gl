package Glitching.AspNetCore;

using System.Collections.Generic;
using Microsoft.Extensions.DependencyInjection;

extern int GlitchRestHost_read_env_int(string name, int fallback);
extern long GlitchRestHost_read_env_i64(string name, long fallback);
extern bool GlitchRestHost_read_env_bool(string name, bool fallback);
extern string GlitchRestHost_read_env_string(string name, string fallback);
extern string GlitchRestHost_read_connection_string(string name, string fallback);

native "
#ifdef _WIN32
#include <winsock2.h>
#include <ws2tcpip.h>
#else
#include <sys/types.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <unistd.h>
#endif

struct WebApplication;
static char * WebApplication_Handle(struct WebApplication * self, char * method, char * path, char * body);
typedef char *(*GlitchEndpointHandler)(void);
typedef char *(*GlitchMiddlewareHandler)(char *);
#ifdef _WIN32
typedef SOCKET glitch_socket_t;
#else
typedef int glitch_socket_t;
#endif

struct GlitchEndpointHandlerEntry {
    struct WebApplication *app;
    char *method;
    char *path;
    GlitchEndpointHandler handler;
};

static struct GlitchEndpointHandlerEntry *GlitchEndpointHandlers = NULL;
static int GlitchEndpointHandlers_len = 0;
static int GlitchEndpointHandlers_cap = 0;

struct GlitchMiddlewareHandlerEntry {
    struct WebApplication *app;
    char *name;
    GlitchMiddlewareHandler handler;
};

static struct GlitchMiddlewareHandlerEntry *GlitchMiddlewareHandlers = NULL;
static int GlitchMiddlewareHandlers_len = 0;
static int GlitchMiddlewareHandlers_cap = 0;

static void GlitchEndpointHandlers_reserve_one(void) {
    if (GlitchEndpointHandlers_len < GlitchEndpointHandlers_cap) { return; }
    GlitchEndpointHandlers_cap = GlitchEndpointHandlers_cap ? GlitchEndpointHandlers_cap * 2 : 8;
    GlitchEndpointHandlers = realloc(GlitchEndpointHandlers, sizeof(struct GlitchEndpointHandlerEntry) * (size_t)GlitchEndpointHandlers_cap);
    if (!GlitchEndpointHandlers) { abort(); }
}

static int GlitchEndpointHandlers_find(struct WebApplication *app, const char *method, const char *path) {
    for (int i = 0; i < GlitchEndpointHandlers_len; i++) {
        struct GlitchEndpointHandlerEntry *entry = &GlitchEndpointHandlers[i];
        if (entry->app == app && strcmp(entry->method, method) == 0 && strcmp(entry->path, path) == 0) {
            return i;
        }
    }
    return -1;
}

static void GlitchEndpointHandlers_Add(struct WebApplication *app, const char *method, const char *path, GlitchEndpointHandler handler) {
    int existing = GlitchEndpointHandlers_find(app, method, path);
    if (existing >= 0) {
        GlitchEndpointHandlers[existing].handler = handler;
        return;
    }
    GlitchEndpointHandlers_reserve_one();
    GlitchEndpointHandlers[GlitchEndpointHandlers_len].app = app;
    GlitchEndpointHandlers[GlitchEndpointHandlers_len].method = glitch_strdup(method);
    GlitchEndpointHandlers[GlitchEndpointHandlers_len].path = glitch_strdup(path);
    GlitchEndpointHandlers[GlitchEndpointHandlers_len].handler = handler;
    GlitchEndpointHandlers_len++;
}

static int GlitchEndpointHandlers_Contains(struct WebApplication *app, const char *method, const char *path) {
    return GlitchEndpointHandlers_find(app, method, path) >= 0;
}

static char * GlitchEndpointHandlers_Invoke(struct WebApplication *app, const char *method, const char *path, const char *body) {
    (void)body;
    int index = GlitchEndpointHandlers_find(app, method, path);
    if (index < 0 || !GlitchEndpointHandlers[index].handler) {
        return glitch_strdup(\"404\");
    }
    return GlitchEndpointHandlers[index].handler();
}

static void GlitchEndpointHandlers_RemoveApp(struct WebApplication *app) {
    int write = 0;
    for (int read = 0; read < GlitchEndpointHandlers_len; read++) {
        struct GlitchEndpointHandlerEntry entry = GlitchEndpointHandlers[read];
        if (entry.app == app) {
            free(entry.method);
            free(entry.path);
            continue;
        }
        if (write != read) {
            GlitchEndpointHandlers[write] = entry;
        }
        write++;
    }
    GlitchEndpointHandlers_len = write;
}

static void GlitchMiddlewareHandlers_reserve_one(void) {
    if (GlitchMiddlewareHandlers_len < GlitchMiddlewareHandlers_cap) { return; }
    GlitchMiddlewareHandlers_cap = GlitchMiddlewareHandlers_cap ? GlitchMiddlewareHandlers_cap * 2 : 8;
    GlitchMiddlewareHandlers = realloc(GlitchMiddlewareHandlers, sizeof(struct GlitchMiddlewareHandlerEntry) * (size_t)GlitchMiddlewareHandlers_cap);
    if (!GlitchMiddlewareHandlers) { abort(); }
}

static void GlitchMiddlewareHandlers_Add(struct WebApplication *app, const char *name, GlitchMiddlewareHandler handler) {
    GlitchMiddlewareHandlers_reserve_one();
    GlitchMiddlewareHandlers[GlitchMiddlewareHandlers_len].app = app;
    GlitchMiddlewareHandlers[GlitchMiddlewareHandlers_len].name = glitch_strdup(name);
    GlitchMiddlewareHandlers[GlitchMiddlewareHandlers_len].handler = handler;
    GlitchMiddlewareHandlers_len++;
}

static char * GlitchMiddlewareHandlers_Apply(struct WebApplication *app, const char *input) {
    char *current = glitch_strdup(input ? input : \"\");
    for (int i = 0; i < GlitchMiddlewareHandlers_len; i++) {
        struct GlitchMiddlewareHandlerEntry *entry = &GlitchMiddlewareHandlers[i];
        if (entry->app != app || !entry->handler) { continue; }
        char *next = entry->handler(current);
        free(current);
        current = next ? next : glitch_strdup(\"\");
    }
    return current;
}

static void GlitchMiddlewareHandlers_RemoveApp(struct WebApplication *app) {
    int write = 0;
    for (int read = 0; read < GlitchMiddlewareHandlers_len; read++) {
        struct GlitchMiddlewareHandlerEntry entry = GlitchMiddlewareHandlers[read];
        if (entry.app == app) {
            free(entry.name);
            continue;
        }
        if (write != read) {
            GlitchMiddlewareHandlers[write] = entry;
        }
        write++;
    }
    GlitchMiddlewareHandlers_len = write;
}

static void GlitchRestHost_close_socket(glitch_socket_t fd) {
#ifdef _WIN32
    closesocket(fd);
#else
    close(fd);
#endif
}

static int GlitchRestHost_send_all(glitch_socket_t fd, const char *data, int len) {
    int sent = 0;
    while (sent < len) {
#ifdef _WIN32
        int n = send(fd, data + sent, len - sent, 0);
#else
        int n = (int)send(fd, data + sent, (size_t)(len - sent), 0);
#endif
        if (n <= 0) { return 0; }
        sent += n;
    }
    return 1;
}

static int GlitchRestHost_read_env_int(const char *name, int fallback) {
    const char *value = getenv(name);
    if (!value || !*value) {
        return fallback;
    }
    int parsed = atoi(value);
    return parsed > 0 ? parsed : fallback;
}

static void GlitchRestHost_Run(struct WebApplication *app, int port, int max_requests) {
#ifdef _WIN32
    WSADATA wsa;
    if (WSAStartup(MAKEWORD(2, 2), &wsa) != 0) { fprintf(stderr, \"WSAStartup failed\\n\"); return; }
#endif
    glitch_socket_t server_fd = socket(AF_INET, SOCK_STREAM, 0);
#ifdef _WIN32
    if (server_fd == INVALID_SOCKET) { fprintf(stderr, \"socket failed\\n\"); return; }
#else
    if (server_fd < 0) { fprintf(stderr, \"socket failed\\n\"); return; }
#endif
    int opt = 1;
#ifdef _WIN32
    setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR, (const char *)&opt, sizeof(opt));
#else
    setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));
#endif
    struct sockaddr_in address;
    memset(&address, 0, sizeof(address));
    address.sin_family = AF_INET;
    address.sin_addr.s_addr = htonl(INADDR_ANY);
    address.sin_port = htons((unsigned short)port);
    if (bind(server_fd, (struct sockaddr *)&address, sizeof(address)) < 0) {
        fprintf(stderr, \"bind failed\\n\");
        GlitchRestHost_close_socket(server_fd);
        return;
    }
    if (listen(server_fd, 16) < 0) {
        fprintf(stderr, \"listen failed\\n\");
        GlitchRestHost_close_socket(server_fd);
        return;
    }
    fprintf(stderr, \"Glitching HTTP host listening on port %d\\n\", port);
    fprintf(stderr, \"Glitching HTTP host entering accept loop\\n\");
    fflush(stderr);
    int handled = 0;
    while (max_requests <= 0 || handled < max_requests) {
        glitch_socket_t client_fd = accept(server_fd, NULL, NULL);
#ifdef _WIN32
        if (client_fd == INVALID_SOCKET) { continue; }
#else
        if (client_fd < 0) { continue; }
#endif
        fprintf(stderr, \"Glitching HTTP host accepted request\\n\");
        fflush(stderr);
        char buffer[4096];
#ifdef _WIN32
        int read_len = recv(client_fd, buffer, sizeof(buffer) - 1, 0);
#else
        int read_len = (int)recv(client_fd, buffer, sizeof(buffer) - 1, 0);
#endif
        if (read_len <= 0) { GlitchRestHost_close_socket(client_fd); continue; }
        buffer[read_len] = 0;
        char method[16] = {0};
        char path[1024] = {0};
        sscanf(buffer, \"%15s %1023s\", method, path);
        char *body = strstr(buffer, \"\\r\\n\\r\\n\");
        body = body ? body + 4 : \"\";
        char *response_body = WebApplication_Handle(app, method, path, body);
        int status = strcmp(response_body, \"404\") == 0 ? 404 : 200;
        const char *status_text = status == 404 ? \"Not Found\" : \"OK\";
        char header[512];
        int body_len = (int)strlen(response_body);
        int header_len = snprintf(header, sizeof(header),
            \"HTTP/1.1 %d %s\\r\\nContent-Type: application/json\\r\\nContent-Length: %d\\r\\nConnection: close\\r\\n\\r\\n\",
            status, status_text, body_len);
        GlitchRestHost_send_all(client_fd, header, header_len);
        GlitchRestHost_send_all(client_fd, response_body, body_len);
        free(response_body);
        GlitchRestHost_close_socket(client_fd);
        handled++;
    }
    GlitchRestHost_close_socket(server_fd);
#ifdef _WIN32
    WSACleanup();
#endif
}
";

public class ConfigurationManager {
    public string Prefix;

    public ConfigurationManager() {
        this.Prefix = "";
    }

    public ConfigurationManager(string prefix) {
        this.Prefix = prefix;
    }

    public string get_Item(string name) {
        string fullName = this.Prefix + name;
        string value = GlitchRestHost_read_env_string(fullName, "");
        return value;
    }

    string GetConnectionString(string name) {
        return GlitchRestHost_read_connection_string(name, "");
    }

    ConfigurationManager GetSection(string name) {
        string sectionPrefix = this.Prefix + name;
        string fullPrefix = sectionPrefix + ":";
        ConfigurationManager section = new ConfigurationManager(fullPrefix);
        return section;
    }

    string Get(string name) {
        return this.get_Item(name);
    }

    T Get<T>() {
        return default(T);
    }

    T GetValue<T>(string name) {
        return default(T);
    }
}

public class HostEnvironment {
    bool IsDevelopment() {
        return false;
    }
}

public class LoggingBuilder {
    void ClearProviders() {
    }

    void AddSerilog(string logger, bool dispose) {
    }
}

public class WebApplicationBuilder {
    public ServiceCollection Services;
    public ConfigurationManager Configuration;
    public HostEnvironment Environment;
    public LoggingBuilder Logging;

    public WebApplicationBuilder() {
        this.Services = new ServiceCollection();
        this.Configuration = new ConfigurationManager();
        this.Environment = new HostEnvironment();
        this.Logging = new LoggingBuilder();
    }

    WebApplication Build() {
        ServiceProvider provider = this.Services.BuildServiceProvider();
        return new WebApplication(move provider);
    }

    void ConfigureSerilog() {}
}

WebApplicationBuilder CreateBuilder(string[] args) {
    return new WebApplicationBuilder();
}

public class HttpRequest {
    public string Method;
    public string Path;
    public Dictionary<string, string> Headers;
    public string Body;

    public HttpRequest(string method, string path, string body) {
        this.Method = method;
        this.Path = path;
        this.Headers = new Dictionary<string, string>();
        this.Body = body;
    }
}

public class HttpResponse {
    public int StatusCode;
    public Dictionary<string, string> Headers;
    public string Body;

    public HttpResponse(int statusCode, string body) {
        this.StatusCode = statusCode;
        this.Headers = new Dictionary<string, string>();
        this.Body = body;
    }
}

public class IPAddress {
    public string Address;

    public IPAddress() {
        this.Address = "127.0.0.1";
    }

    string ToString() {
        return this.Address;
    }
}

public class ConnectionInfo {
    public IPAddress RemoteIpAddress;

    public ConnectionInfo() {
        this.RemoteIpAddress = new IPAddress();
    }
}

public class HttpContext {
    public HttpRequest Request;
    public HttpResponse Response;
    public ConnectionInfo Connection;
    public string TraceIdentifier;

    public HttpContext(HttpRequest request) {
        this.Request = move request;
        this.Response = new HttpResponse(200, "");
        this.Connection = new ConnectionInfo();
        this.TraceIdentifier = "trace";
    }

    void WriteJson(string text) {
        this.Response.Body = text;
        this.Response.Headers.Add("Content-Type", "application/json");
    }
}

public interface IHttpContextAccessor {
    public HttpContext HttpContext;
}

public class HttpContextAccessor : IHttpContextAccessor {
    public HttpContext HttpContext;
}

