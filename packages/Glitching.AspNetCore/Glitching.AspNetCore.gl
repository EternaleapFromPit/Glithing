public class ActionExecutingContext {
    public Dictionary<string, object> ActionArguments;
    public ModelStateDictionary ModelState;
    public HttpContext HttpContext;
    public object Result;
}

public class ExceptionContext {
    public object Exception;
    public HttpContext HttpContext;
    public object Result;
    public bool ExceptionHandled;
}

public class ModelError {
    public string ErrorMessage;
}

public class ModelStateEntry {
    public List<ModelError> Errors;

    public ModelStateEntry() {
        this.Errors = new List<ModelError>();
    }
}

public class ModelStateDictionary {
    public bool IsValid;
    public Dictionary<string, ModelStateEntry> Entries;

    public ModelStateDictionary() {
        this.IsValid = true;
        this.Entries = new Dictionary<string, ModelStateEntry>();
    }

    void AddModelError(string key, string message) {
        this.IsValid = false;
        ModelStateEntry entry = null;
        if (!this.Entries.TryGetValue(key, out entry)) {
            entry = new ModelStateEntry();
            this.Entries.Add(key, entry);
        }
        entry.Errors.Add(new ModelError { ErrorMessage = message });
    }
    Dictionary<string, ModelStateEntry> ToDictionary() {
        return this.Entries;
    }
}

public class ControllerBase {
    public ModelStateDictionary ModelState;
    public HttpContext HttpContext;

    public ControllerBase() {
        this.ModelState = new ModelStateDictionary();
    }

    object Ok(object value) { return value; }
    object Ok() { return ""; }
    object BadRequest(object error) { return error; }
    object NotFound() { return "Not Found"; }
    object StatusCode(int code, object value) { return value; }
}
