    CorsPolicyBuilder AllowAnyOrigin() {
        return new CorsPolicyBuilder();
    }

    CorsPolicyBuilder AllowAnyHeader() {
        return new CorsPolicyBuilder();
    }

    CorsPolicyBuilder AllowAnyMethod() {
        return new CorsPolicyBuilder();
    }
}

public delegate void CorsConfigure(CorsPolicyBuilder options);
public delegate void SwaggerOptionsConfigure(SwaggerOptions options);
public delegate void SwaggerUiOptionsConfigure(SwaggerUiOptions options);

public class SwaggerOptions {
    public string RouteTemplate;
}

public class SwaggerUiOptions {
    void SwaggerEndpoint(string url, string name) {}
}

public class CorsMiddlewareOptions {
}

public class Endpoint {
    public string Method;
    public string Path;
    public string Text;

    public Endpoint(string method, string path, string text) {
        this.Method = method;
        this.Path = path;
        this.Text = text;
    }
}

public class WebApplication {
    public List<string> Routes;
    public Dictionary<string, string> Responses;
    public List<string> Middleware;
    
    public ConfigurationManager Configuration;
    public ServiceProvider Services;
    public HostEnvironment Environment;

    public WebApplication() {
        this.Routes = new List<string>();
        this.Responses = new Dictionary<string, string>();
        this.Middleware = new List<string>();
        this.Configuration = new ConfigurationManager();
        this.Services = new ServiceProvider();
        this.Environment = new HostEnvironment();
        glitch_register_attribute_routes(this);
    }

    public WebApplication(ServiceProvider services) {
        this.Routes = new List<string>();
        this.Responses = new Dictionary<string, string>();
        this.Middleware = new List<string>();
        this.Configuration = new ConfigurationManager();
        this.Services = move services;
        this.Environment = new HostEnvironment();
        glitch_register_attribute_routes(this);
    }

    void Use(string name) {
        this.Middleware.Add(name);
    }

    void UseRouting() {
        this.Use("routing");
    }

    void UseEndpoints() {
        this.Use("endpoints");
    }

    void UseTrace() {
        this.Use("trace");
    }

    void UseJsonEnvelope() {
        this.Use("json-envelope");
    }

    void UseHttpsRedirection() {
        this.Use("https-redirection");
    }

    void UseAuthorization() {
        this.Use("authorization");
    }

    void UseAuthentication() {
        this.Use("authentication");
    }

    void UseCors(string policy) {
        this.Use("cors");
    }

    void UseCors(CorsConfigure configure) {
        this.Use("cors");
    }
    
    void UseCors() {
        this.Use("cors");
    }

    void UseMiddleware<T>() {}
    void UseMiddleware<T>(object param) {}
    void UseSwagger() {}
    void UseSwagger(SwaggerOptionsConfigure configure) {}
    void UseSwaggerUI(SwaggerUiOptionsConfigure configure) {}
    void UseSwaggerUI() {}
    void UseStaticFiles(object options) {}
    void UseStaticFiles() {}

    void MapControllers() {
        this.Use("controllers");
    }

    void MapGet<T>(string path, Func<T> handler) {
        string key = "GET " + path;
        this.Routes.Add(key);
    }

    void MapGet(string path, string text) {
        string key = "GET " + path;
        this.Routes.Add(key);
        this.Responses.Add(key, text);
    }

    void MapPost<T>(string path, Func<T> handler) {
        string key = "POST " + path;
        this.Routes.Add(key);
    }

    void MapPost(string path, string text) {
        string key = "POST " + path;
        this.Routes.Add(key);
        this.Responses.Add(key, text);
    }

    string Handle(string method, string path, string body) {
        string methodPrefix = method + " ";
        string key = methodPrefix + path;
        if (GlitchEndpointHandlers_Contains(this, method, path)) {
            string handlerResponse = GlitchEndpointHandlers_Invoke(this, method, path, body);
            return this.ApplyMiddleware(handlerResponse);
        } else {
            if (this.Responses.ContainsKey(key)) {
                return this.ApplyMiddleware(this.Responses[key]);
            } else {
                return "404";
            }
        }
    }

    string ApplyMiddleware(string text) {
        string current = GlitchMiddlewareHandlers_Apply(this, text);
        if (this.Middleware.Contains("json-envelope")) {
            string prefix = "{\"result\":";
            string withPrefix = prefix + current;
            return withPrefix + "}";
        }
        if (this.Middleware.Contains("trace")) {
            string prefix = "trace:";
            return prefix + current;
        }
        return current;
    }

    void Run(int port) {
        GlitchRestHost_Run(this, port, GlitchRestHost_read_env_int("GLITCH_HTTP_MAX_REQUESTS", 0));
    }

    void Run() {
        GlitchRestHost_Run(
            this,
            GlitchRestHost_read_env_int("GLITCH_HTTP_PORT", 5000),
            GlitchRestHost_read_env_int("GLITCH_HTTP_MAX_REQUESTS", 0)
        );
    }

    void RunOnce(int port) {
        GlitchRestHost_Run(this, port, 1);
    }
}

