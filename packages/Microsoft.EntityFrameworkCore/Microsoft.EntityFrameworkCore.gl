    public DebugView DebugView;
    public ChangeTracker() {
        this.DebugView = new DebugView();
    }
    void DetectChanges() {}
    void Clear() {}
}

class DebugView {
    public string LongView;
}

class DatabaseFacade {
    public string ConnectionString;

    public DatabaseFacade() {
        this.ConnectionString = "";
    }

    public DatabaseFacade(string connectionString) {
        this.ConnectionString = connectionString;
    }

    bool EnsureCreated() { return true; }
    bool EnsureDeleted() { return false; }
    bool IsInMemory() { return this.ConnectionString == "inmemory"; }
    IDbContextTransaction BeginTransaction(object isolationLevel) {
        return new DatabaseTransaction();
    }
    void Migrate() {}
    int ExecuteSqlRaw(string sql, object parameters) { return 0; }
}

class DatabaseTransaction : IDbContextTransaction {
    void Commit() {}
    void Rollback() {}
    void Dispose() {}
}

enum EntityState {
    Detached,
    Unchanged,
    Deleted,
    Modified,
    Added
}

class EntityEntry {
    public EntityState State;
}

class DbUpdateConcurrencyException : Exception {
}

class DbContext {
    public string ConnectionString;
    public bool IsDisposed;
    public List<string> TrackedEntities;
    public SqlProvider Provider;
    public DatabaseFacade Database;
    public ChangeTracker ChangeTracker;

    public DbContext(string connectionString) {
        this.ConnectionString = connectionString;
        this.IsDisposed = false;
        this.TrackedEntities = new List<string>();
        this.Provider = new SqlProvider("sql", connectionString);
        this.Database = new DatabaseFacade(connectionString);
        this.ChangeTracker = new ChangeTracker();
    }

    public DbContext(object options) {
        this.ConnectionString = "";
        this.IsDisposed = false;
        this.TrackedEntities = new List<string>();
        this.Provider = new SqlProvider("sql", "");
        this.Database = new DatabaseFacade();
        this.ChangeTracker = new ChangeTracker();
    }

    public DbContext(DbContextOptions options) {
        this.ConnectionString = options.ConnectionString;
        this.IsDisposed = false;
        this.TrackedEntities = new List<string>();
        this.Provider = new SqlProvider("sql", this.ConnectionString);
        this.Database = new DatabaseFacade(this.ConnectionString);
        this.ChangeTracker = new ChangeTracker();
    }

    void EnsureNotDisposed() {
        if (this.IsDisposed) {
            throw new Exception("DbContext is disposed");
        }
    }

    void Track(string entityKey) {
        this.EnsureNotDisposed();
        this.TrackedEntities.Add(entityKey);
    }

    int TrackedCount => this.TrackedEntities.Count;

    int SaveChanges() {
        this.EnsureNotDisposed();
        int count = this.TrackedEntities.Count;
        this.TrackedEntities.Clear();
        return count;
    }

    Task<int> SaveChangesAsync() {
        this.EnsureNotDisposed();
        int count = this.TrackedEntities.Count;
        this.TrackedEntities.Clear();
        return new Task<int>();
    }

    void Add(string entityKey) {
        this.Track(entityKey);
    }

    void Update(string entityKey) {
        this.Track(entityKey);
    }

    void Remove(string entityKey) {
        this.EnsureNotDisposed();
    }

    void Dispose() {
        this.IsDisposed = true;
        this.TrackedEntities.Clear();
    }

    DbSet<T> Set<T>() {
        return new DbSet<T>();
    }

    EntityEntry Entry(object entity) {
        return new EntityEntry();
    }
}

class IQueryableString {
    public string ConnectionString;
    public string Table;
    public bool Tracking;

    public IQueryableString(string connectionString, string table, bool tracking) {
        this.ConnectionString = connectionString;
        this.Table = table;
        this.Tracking = tracking;
    }

    IQueryableString AsNoTracking() {
        return new IQueryableString(this.ConnectionString, this.Table, false);
    }

    string ToQueryString() {
        SqlProvider provider = new SqlProvider("sql", this.ConnectionString);
        return provider.BuildSelectAll(this.Table);
    }

    List<string> ToList() {
        List<string> values = new List<string>();
        string query = this.ToQueryString();
        if (this.Tracking) {
            string prefix = "tracked:";
            values.Add(prefix + query);
        } else {
            values.Add(query);
        }
        return values;
    }
}

class DbSetString {
    public string ConnectionString;
    public string Table;

    public DbSetString(string connectionString, string table) {
        this.ConnectionString = connectionString;
        this.Table = table;
    }

    IQueryableString AsQueryable() {
        return new IQueryableString(this.ConnectionString, this.Table, true);
    }

    IQueryableString AsNoTracking() {
        return new IQueryableString(this.ConnectionString, this.Table, false);
    }

    List<string> ToList() {
        return this.AsQueryable().ToList();
    }
}

DbSetString SetString(DbContext context, string table) {
    context.EnsureNotDisposed();
    return new DbSetString(context.ConnectionString, table);
}

