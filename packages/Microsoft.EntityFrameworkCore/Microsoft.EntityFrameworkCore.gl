class SqlProvider {
    public string Name;
    public string ConnectionString;

    public SqlProvider(string name, string connectionString) {
        this.Name = name;
        this.ConnectionString = connectionString;
    }

    string BuildSelectAll(string table) {
        string prefix = "select * from ";
        return prefix + table;
    }
}

